# Elastic Cloud Serverless
# Endpoint: Cloud console → project → Copy endpoint (Elasticsearch)
# Format:   https://<project-id>.es.<region>.aws.elastic.cloud
ES_HOST=https://<project-id>.es.<region>.gcp.elastic.cloud:443

# API key: Cloud console → project → API Keys → Create
ES_API_KEY=your_api_key_here

# Crawler version
CRAWLER_VERSION=latest

# Target index name
ES_INDEX=rijksoverheid-qa-v3

# Target site to crawl
CRAWL_URL=https://www.rijksoverheid.nl
